{
  "name": "desirability-backend",
  "version": "1.0.0",
  "description": "Production-ready activity scoring and top cities recommendation engine",
  "private": true,
  "main": "src/index.ts",
  "scripts": {
    "ensure:redis": "node scripts/dev/ensure-redis.js",
    "dev": "npm run ensure:redis && ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc -p .",
    "start": "node dist/index.js",
    "seed": "ts-node src/db/seed.ts",
    "db:reset": "ts-node src/db/reset.ts",
    "precompute": "ts-node src/jobs/runPrecompute.ts",
    "coastline:download:world": "bash scripts/coastline/download-world-coastline.sh",
    "coastline:build:world": "bash scripts/coastline/build-world-coastline-geojson.sh"
  },
  "dependencies": {
    "apollo-server": "^3.13.0",
    "apollo-server-express": "^3.13.0",
    "better-sqlite3": "^9.0.0",
    "dotenv": "^16.0.3",
    "express": "^4.22.1",
    "geojson-rbush": "^3.2.0",
    "graphql": "^16.6.0",
    "ioredis": "^5.3.0",
    "p-limit": "^3.1.0",
    "stream-chain": "^2.2.5",
    "stream-json": "^1.9.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^4.17.14",
    "@types/node": "^20.3.1",
    "@types/stream-chain": "^2.1.0",
    "@types/stream-json": "^1.7.8",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.1.6"
  }
}
