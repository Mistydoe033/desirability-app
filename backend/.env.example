# Logging
LOG_LEVEL=INFO

# External APIs
WEATHER_API_BASE_URL=https://api.open-meteo.com/v1
WEATHER_ARCHIVE_API_BASE_URL=https://archive-api.open-meteo.com/v1
MARINE_API_BASE_URL=https://marine-api.open-meteo.com/v1
GEOCODING_API_BASE_URL=https://geocoding-api.open-meteo.com/v1
OVERPASS_API_INTERPRETER_URL=https://overpass-api.de/api/interpreter
COASTLINE_GEOJSON_PATH=./data/coastline.geojson
COASTLINE_MAX_POINTS_PER_LINE=256
FORECAST_DAYS=7
API_REQUEST_TIMEOUT_MS=10000
API_MAX_RETRIES=3
API_RETRY_DELAY_MS=1000

# Redis
REDIS_URL=redis://localhost:6379
REDIS_OP_TIMEOUT_MS=250
CACHE_TTL_MINUTES=60
PRECOMPUTE_CACHE_TTL_MINUTES=120

# SQLite
DB_PATH=./data/activities.db

# Concurrency limits
API_CONCURRENCY_LIMIT=5
PRECOMPUTE_CONCURRENCY_LIMIT=3

# Jobs
PRECOMPUTE_INTERVAL_MINUTES=360
PRECOMPUTE_TOP_CITIES_LIMIT=20
PRECOMPUTE_CANDIDATE_LIMIT=100
FEATURE_COMPUTE_INTERVAL_MINUTES=720

# GraphQL
GRAPHQL_PORT=4000
GRAPHQL_HOST=0.0.0.0
